# Companion workers for NVIDIA Brev
# Copy to .env.brev and replace the placeholders with the images/commands
# that match your LLM and TTS containers.

# LLM worker
LLM_IMAGE=ghcr.io/your-org/llm-worker:latest
LLM_CONTAINER_PORT=8080
LLM_HOST_PORT=8080
LLM_MODEL=qwen-3.5
LLM_START_COMMAND=python -m your_llm_server --host 0.0.0.0 --port 8080

# TTS worker
TTS_IMAGE=ghcr.io/your-org/tts-worker:latest
TTS_CONTAINER_PORT=8001
TTS_HOST_PORT=8001
TTS_API_PATH=/tts
TTS_LANGUAGE=en
TTS_VOICE=default_voice
TTS_START_COMMAND=python -m your_tts_server --host 0.0.0.0 --port 8001
